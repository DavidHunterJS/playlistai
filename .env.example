# Copy to .env and fill in your values
# Usage: export $(grep -v '^#' .env | xargs)

PLAYLISTAI_MUSIC_ROOT=/music
PLAYLISTAI_DB_PATH=/home/user/playlistai/playlistai.db
PLAYLISTAI_PLAYLIST_DIR=/music/playlists
PLAYLISTAI_EXPLORED_CUTOFF=2021-08-31

# Subsonic API (Phase 6)
SUBSONIC_URL=https://your-seedbox.example.com
SUBSONIC_USER=youruser
SUBSONIC_PASS=yourpassword
